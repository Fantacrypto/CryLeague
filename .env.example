# Copia questo file come .env nella cartella del progetto
# Trovi questi valori su Supabase → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Parola segreta per accedere al pannello admin
# Es: tuosito.com?admin=questa-parola
VITE_ADMIN_SECRET=scegli-una-parola-segreta

# Password per il login admin
VITE_ADMIN_PASSWORD=scegli-una-password-sicura
